<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ULiAN | Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #0a0a0d; --bg-soft: #121218; --card: rgba(255,255,255,0.03);
            --card-border: rgba(255,255,255,0.08); --text: #f5f5f7; --muted: #b7b7c0;
            --accent: #ff5f87; --accent-2: #ff7aa1; --danger: #ff4757; --success: #2ed573; --radius: 16px;
        }

        body { font-family: 'Inter', sans-serif; background: radial-gradient(circle at top right, rgba(255,95,135,0.08), transparent 25%), var(--bg); color: var(--text); margin: 0; padding: 2rem; min-height: 100vh; }
        .noise { position: fixed; inset: 0; pointer-events: none; opacity: 0.035; background-image: radial-gradient(circle, #fff 0.8px, transparent 0.8px); background-size: 12px 12px; z-index: -1; }
        .header-dashboard { text-align: center; margin-bottom: 3rem; }
        .header-dashboard h1 { margin: 0; color: var(--text); font-size: 2.5rem; letter-spacing: -0.03em; }
        .header-dashboard p { color: var(--muted); margin-top: 5px; }

        .dashboard-wrapper { max-width: 1200px; margin: auto; display: grid; grid-template-columns: 1fr 1.5fr; gap: 2rem; }
        .full-width { grid-column: 1 / -1; margin-bottom: 1rem; }

        .dashboard-box { background: var(--card); border: 1px solid var(--card-border); backdrop-filter: blur(10px); padding: 2.5rem; border-radius: var(--radius); box-shadow: 0 10px 30px rgba(0,0,0,0.2); }
        .dashboard-box h2 { margin-top: 0; font-size: 1.3rem; border-bottom: 1px solid var(--card-border); padding-bottom: 15px; margin-bottom: 25px; display: flex; align-items: center; gap: 12px; color: var(--white); }

        label { font-weight: 600; font-size: 0.85rem; color: var(--muted); display: block; margin-bottom: 8px; margin-top: 1.5rem; text-transform: uppercase; letter-spacing: 0.05em; }
        input[type="text"], textarea, input[type="file"] { width: 100%; padding: 12px 15px; background: rgba(0,0,0,0.2); border: 1px solid var(--card-border); color: var(--text); border-radius: 8px; font-family: 'Inter', sans-serif; box-sizing: border-box; transition: all 0.3s ease; }
        input::placeholder, textarea::placeholder { color: #555; }
        input:focus, textarea:focus { outline: none; border-color: var(--accent); background: rgba(0,0,0,0.4); box-shadow: 0 0 0 3px rgba(255,95,135,0.1); }

        .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 30px; }

        button.btn-submit { background: linear-gradient(135deg, var(--accent), var(--accent-2)); color: white; border: none; padding: 14px 24px; border-radius: 8px; cursor: pointer; font-size: 1rem; font-weight: 700; width: 100%; margin-top: 2rem; transition: transform 0.2s, box-shadow 0.2s; box-shadow: 0 5px 15px rgba(255,95,135,0.2); }
        button.btn-submit:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(255,95,135,0.3); }
        .btn-secondary { background: transparent; border: 1px solid var(--accent); color: var(--accent); box-shadow: none; }
        .btn-secondary:hover { background: rgba(255,95,135,0.1); box-shadow: none; }

        .project-list { list-style: none; padding: 0; margin: 0; }
        .project-item { display: flex; align-items: center; background: rgba(0,0,0,0.2); padding: 18px; margin-bottom: 12px; border: 1px solid var(--card-border); border-radius: 12px; transition: all 0.2s ease; }
        .project-item:hover { background: rgba(255,255,255,0.03); border-color: rgba(255,255,255,0.15); }
        .drag-handle { cursor: grab; margin-right: 15px; color: #555; font-size: 1.2rem; }
        .project-info { flex-grow: 1; }
        .project-title { font-weight: 600; color: var(--white); display: block; font-size: 1.1rem;}
        .project-desc { font-size: 0.85rem; color: var(--muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 250px; display: block; margin-top: 4px;}

        .project-actions { display: flex; gap: 8px; }
        .btn-action { background: rgba(255,255,255,0.05); border: 1px solid var(--card-border); padding: 8px 12px; border-radius: 6px; cursor: pointer; font-size: 0.9rem; transition: all 0.2s; color: var(--text); }
        .btn-action:hover { background: rgba(255,255,255,0.1); }
        .btn-delete { color: var(--danger); }
        .btn-delete:hover { background: rgba(255,71,87,0.1); border-color: rgba(255,71,87,0.3); }

        .nav-links { text-align: center; margin-top: 3rem; }
        .nav-links a { color: var(--muted); text-decoration: none; font-size: 0.95rem; transition: color 0.3s; border-bottom: 1px solid transparent; padding-bottom: 2px;}
        .nav-links a:hover { color: var(--white); border-color: var(--white);}

        @media (max-width: 900px) { .dashboard-wrapper { grid-template-columns: 1fr; } .form-row { grid-template-columns: 1fr; gap: 15px;} }
    </style>
</head>
<body>

<div class="noise"></div>

<div class="header-dashboard">
    <h1>Pannello di Controllo</h1>
    <p>Gestisci l'identità del tuo studio e il tuo portfolio</p>
</div>

<div class="dashboard-wrapper">

    <div class="dashboard-box full-width">
        <h2><span>🏢</span> Gestione Sezione Studio (Chi Siamo)</h2>
        <form action="/update-about" method="POST" enctype="multipart/form-data">
            <div class="form-row">
                <div>
                    <label>Titolo Presentazione</label>
                    <input type="text" name="about_title" placeholder="Es. Costruiamo Identità Memorabili..." value="<%= typeof about !== 'undefined' && about.title ? about.title : '' %>">
                    <label>Immagine Studio</label>
                    <input type="file" name="about_image" accept="image/*">
                    <small style="color: var(--muted); display: block; margin-top: 5px;">Lascia vuoto per mantenere l'immagine attuale.</small>
                </div>
                <div>
                    <label>Testo Descrittivo</label>
                    <textarea name="about_description" rows="5" placeholder="Racconta la filosofia del tuo studio..."><%= typeof about !== 'undefined' && about.description ? about.description : '' %></textarea>
                </div>
            </div>
            <button type="submit" class="btn-submit btn-secondary" style="width: auto; padding: 12px 40px;">Salva Modifiche Studio</button>
        </form>
    </div>

    <div class="dashboard-box">
        <h2><span>✨</span> Nuovo Servizio</h2>
        <form action="/add-service" method="POST">
            <label>Nome Servizio</label>
            <input type="text" name="title" placeholder="Es. Produzione Video" required>
            <label>Icona (Usa Emoji)</label>
            <input type="text" name="icon" placeholder="🎬" required>
            <label>Tags (separati da virgola)</label>
            <input type="text" name="tags" placeholder="Es. Spot TV, Brand Film">
            <label>Descrizione</label>
            <textarea name="description" rows="3" placeholder="Descrivi il servizio offerto..." required></textarea>
            <button type="submit" class="btn-submit">Aggiungi Servizio</button>
        </form>
    </div>

    <div class="dashboard-box">
        <h2><span>🛠️</span> I Tuoi Servizi</h2>
        <ul class="project-list">
            <% if (typeof services !== 'undefined' && services.length > 0) { %>
                <% services.forEach(function(service) { %>
                    <li class="project-item">
                        <span class="drag-handle">☰</span>
                        <div class="project-info" style="display: flex; gap: 15px; align-items: center;">
                            <span style="font-size: 1.5rem;"><%= service.icon %></span>
                            <div>
                                <span class="project-title"><%= service.title %></span>
                                <span class="project-desc"><%= service.description %></span>
                            </div>
                        </div>
                        <div class="project-actions">
                            <form action="/delete-service/<%= service.id %>" method="POST" style="display:inline;" onsubmit="return confirm('Sei sicuro di voler eliminare questo servizio?');">
                                <button type="submit" class="btn-action btn-delete" title="Elimina">🗑️</button>
                            </form>
                        </div>
                    </li>
                <% }); %>
            <% } else { %>
                <div style="text-align: center; padding: 2rem 0;">
                    <span style="font-size: 2rem; opacity: 0.5;">📭</span>
                    <p style="color: var(--muted); margin-top: 10px;">Nessun servizio inserito.</p>
                </div>
            <% } %>
        </ul>
    </div>

    <div class="dashboard-box">
        <h2><span>✨</span> Nuovo Progetto Portfolio</h2>
        <form action="/add-project" method="POST" enctype="multipart/form-data">
            <label>Titolo del progetto</label>
            <input type="text" name="title" placeholder="Es. Shooting Moda..." required>
            <label>Descrizione</label>
            <textarea name="description" rows="4" placeholder="Descrivi il lavoro svolto..." required></textarea>

            <label>Immagini (Seleziona più foto contemporaneamente)</label>
            <input type="file" name="images" accept="image/*" multiple required>
            <small style="color: var(--accent); display: block; margin-top: 5px;">Puoi selezionare fino a 10 immagini. La prima sarà la copertina.</small>

            <button type="submit" class="btn-submit">Pubblica Galleria</button>
        </form>
    </div>

    <div class="dashboard-box">
        <h2><span>🖼️</span> I Tuoi Lavori</h2>
        <ul class="project-list">
            <% if (typeof projects !== 'undefined' && projects.length > 0) { %>
                <% projects.forEach(function(project) { %>
                    <li class="project-item">
                        <span class="drag-handle">☰</span>
                        <div class="project-info">
                            <span class="project-title"><%= project.title %></span>
                            <span class="project-desc">
                                📷 <%= project.images.length %> Foto inserite
                            </span>
                        </div>
                        <div class="project-actions">
                            <form action="/delete-project/<%= project.id %>" method="POST" style="display:inline;" onsubmit="return confirm('Eliminare definitivamente questo progetto e la sua galleria?');">
                                <button type="submit" class="btn-action btn-delete" title="Elimina">🗑️</button>
                            </form>
                        </div>
                    </li>
                <% }); %>
            <% } else { %>
                <div style="text-align: center; padding: 2rem 0;">
                    <span style="font-size: 2rem; opacity: 0.5;">📁</span>
                    <p style="color: var(--muted); margin-top: 10px;">Nessun progetto caricato.</p>
                </div>
            <% } %>
        </ul>
    </div>

</div>

<div class="nav-links">
    <a href="/">← Torna al sito web pubblico</a>
</div>

</body>
</html>