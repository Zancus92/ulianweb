<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ULiAN | Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #0a0a0d; --bg-soft: #121218; --card: rgba(255,255,255,0.03);
            --card-border: rgba(255,255,255,0.08); --text: #f5f5f7; --muted: #b7b7c0;
            --accent: #ff5f87; --accent-2: #ff7aa1; --danger: #ff4757; --success: #2ed573; --radius: 16px;
        }

        body { font-family: 'Inter', sans-serif; background: radial-gradient(circle at top right, rgba(255,95,135,0.08), transparent 25%), var(--bg); color: var(--text); margin: 0; padding: 2rem; min-height: 100vh; }
        .noise { position: fixed; inset: 0; pointer-events: none; opacity: 0.035; background-image: radial-gradient(circle, #fff 0.8px, transparent 0.8px); background-size: 12px 12px; z-index: -1; }
        .header-dashboard { text-align: center; margin-bottom: 3rem; }
        .header-dashboard h1 { margin: 0; color: var(--text); font-size: 2.5rem; letter-spacing: -0.03em; }
        .header-dashboard p { color: var(--muted); margin-top: 5px; }

        .dashboard-wrapper { max-width: 1200px; margin: auto; display: grid; grid-template-columns: 1fr 1.5fr; gap: 2rem; }
        .full-width { grid-column: 1 / -1; margin-bottom: 1rem; }

        .dashboard-box { background: var(--card); border: 1px solid var(--card-border); backdrop-filter: blur(10px); padding: 2.5rem; border-radius: var(--radius); box-shadow: 0 10px 30px rgba(0,0,0,0.2); }
        .dashboard-box h2 { margin-top: 0; font-size: 1.3rem; border-bottom: 1px solid var(--card-border); padding-bottom: 15px; margin-bottom: 25px; display: flex; align-items: center; gap: 12px; color: var(--white); }

        label { font-weight: 600; font-size: 0.85rem; color: var(--muted); display: block; margin-bottom: 8px; margin-top: 1.5rem; text-transform: uppercase; letter-spacing: 0.05em; }
        input[type="text"], textarea, input[type="file"] { width: 100%; padding: 12px 15px; background: rgba(0,0,0,0.2); border: 1px solid var(--card-border); color: var(--text); border-radius: 8px; font-family: 'Inter', sans-serif; box-sizing: border-box; transition: all 0.3s ease; }
        input::placeholder, textarea::placeholder { color: #555; }
        input:focus, textarea:focus { outline: none; border-color: var(--accent); background: rgba(0,0,0,0.4); box-shadow: 0 0 0 3px rgba(255,95,135,0.1); }

        .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 30px; }

        button.btn-submit { background: linear-gradient(135deg, var(--accent), var(--accent-2)); color: white; border: none; padding: 14px 24px; border-radius: 8px; cursor: pointer; font-size: 1rem; font-weight: 700; width: 100%; margin-top: 2rem; transition: transform 0.2s, box-shadow 0.2s; box-shadow: 0 5px 15px rgba(255,95,135,0.2); }
        button.btn-submit:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(255,95,135,0.3); }
        button.btn-submit:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }

        .btn-secondary { background: transparent; border: 1px solid var(--accent); color: var(--accent); box-shadow: none; }
        .btn-secondary:hover { background: rgba(255,95,135,0.1); box-shadow: none; }

        .project-list { list-style: none; padding: 0; margin: 0; }
        .project-item { display: flex; align-items: center; background: rgba(0,0,0,0.2); padding: 18px; margin-bottom: 12px; border: 1px solid var(--card-border); border-radius: 12px; transition: all 0.2s ease; }
        .project-item:hover { background: rgba(255,255,255,0.03); border-color: rgba(255,255,255,0.15); }
        .drag-handle { cursor: grab; margin-right: 15px; color: #555; font-size: 1.2rem; }
        .project-info { flex-grow: 1; }
        .project-title { font-weight: 600; color: var(--white); display: block; font-size: 1.1rem;}
        .project-desc { font-size: 0.85rem; color: var(--muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 250px; display: block; margin-top: 4px;}

        .project-actions { display: flex; gap: 8px; }
        .btn-action { background: rgba(255,255,255,0.05); border: 1px solid var(--card-border); padding: 8px 12px; border-radius: 6px; cursor: pointer; font-size: 0.9rem; transition: all 0.2s; color: var(--text); }
        .btn-action:hover { background: rgba(255,255,255,0.1); }
        .btn-delete { color: var(--danger); }
        .btn-delete:hover { background: rgba(255,71,87,0.1); border-color: rgba(255,71,87,0.3); }

        .nav-links { text-align: center; margin-top: 3rem; }
        .nav-links a { color: var(--muted); text-decoration: none; font-size: 0.95rem; transition: color 0.3s; border-bottom: 1px solid transparent; padding-bottom: 2px;}
        .nav-links a:hover { color: var(--white); border-color: var(--white);}

        .reorder-modal { display: none; position: fixed; z-index: 1000; left: 0; top: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.85); backdrop-filter: blur(10px); align-items: center; justify-content: center; padding: 20px; box-sizing: border-box; }
        .media-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; max-height: 50vh; overflow-y: auto; padding-right: 5px; }
        .media-item { display: flex; align-items: center; background: rgba(0,0,0,0.3); padding: 10px 15px; border: 1px solid var(--card-border); border-radius: 8px; cursor: grab; transition: background 0.2s; }
        .media-item:hover { background: rgba(255,255,255,0.05); }
        .media-item.dragging { opacity: 0.5; border: 2px dashed var(--accent); }
        .media-thumbnail { width: 50px; height: 50px; object-fit: cover; border-radius: 6px; margin-right: 15px; background: #000; }
        .media-list::-webkit-scrollbar { width: 6px; }
        .media-list::-webkit-scrollbar-thumb { background: var(--card-border); border-radius: 10px; }

        @media (max-width: 900px) { .dashboard-wrapper { grid-template-columns: 1fr; } .form-row { grid-template-columns: 1fr; gap: 15px;} }
    </style>
</head>
<body>

<div class="noise"></div>

<div class="header-dashboard">
    <h1>Pannello di Controllo</h1>
    <p>Gestisci l'identità del tuo studio e il tuo portfolio</p>
</div>

<div class="dashboard-wrapper">

    <div class="dashboard-box full-width">
        <h2><span>🏢</span> Gestione Sezione Studio (Chi Siamo)</h2>
        <form action="/update-about" method="POST" enctype="multipart/form-data">
            <div class="form-row">
                <div>
                    <label>Titolo Presentazione</label>
                    <input type="text" name="about_title" placeholder="Es. Costruiamo Identità Memorabili..." value="<%= typeof about !== 'undefined' && about.title ? about.title : '' %>">
                    <label>Immagine Studio</label>
                    <input type="file" name="about_image" accept="image/*">
                    <small style="color: var(--muted); display: block; margin-top: 5px;">Lascia vuoto per mantenere l'immagine attuale.</small>
                </div>
                <div>
                    <label>Testo Descrittivo</label>
                    <textarea name="about_description" rows="5" placeholder="Racconta la filosofia del tuo studio..."><%= typeof about !== 'undefined' && about.description ? about.description : '' %></textarea>
                </div>
            </div>
            <button type="submit" class="btn-submit btn-secondary" style="width: auto; padding: 12px 40px;">Salva Modifiche Studio</button>
        </form>
    </div>

    <div class="dashboard-box">
        <h2><span>✨</span> Nuovo Servizio</h2>
        <form action="/add-service" method="POST">
            <label>Nome Servizio</label>
            <input type="text" name="title" placeholder="Es. Produzione Video" required>
            <label>Icona (Usa Emoji)</label>
            <input type="text" name="icon" placeholder="🎬" required>
            <label>Tags (separati da virgola)</label>
            <input type="text" name="tags" placeholder="Es. Spot TV, Brand Film">
            <label>Descrizione</label>
            <textarea name="description" rows="3" placeholder="Descrivi il servizio offerto..." required></textarea>
            <button type="submit" class="btn-submit">Aggiungi Servizio</button>
        </form>
    </div>

    <div class="dashboard-box">
        <h2><span>🛠️</span> I Tuoi Servizi</h2>
        <ul class="project-list">
            <% if (typeof services !== 'undefined' && services.length > 0) { %>
                <% services.forEach(function(service) { %>
                    <li class="project-item">
                        <span class="drag-handle">☰</span>
                        <div class="project-info" style="display: flex; gap: 15px; align-items: center;">
                            <span style="font-size: 1.5rem;"><%= service.icon %></span>
                            <div>
                                <span class="project-title"><%= service.title %></span>
                                <span class="project-desc"><%= service.description %></span>
                            </div>
                        </div>
                        <div class="project-actions">
                            <button type="button" class="btn-action"
                                    data-id="<%= service.id %>"
                                    data-title="<%= service.title %>"
                                    data-icon="<%= service.icon %>"
                                    data-desc="<%= service.description %>"
                                    data-tags="<%= service.tags %>"
                                    onclick="openEditServiceModal(this)" title="Modifica Servizio">✏️</button>

                            <form action="/delete-service/<%= service.id %>" method="POST" style="display:inline;" onsubmit="return confirm('Sei sicuro di voler eliminare questo servizio?');">
                                <button type="submit" class="btn-action btn-delete" title="Elimina">🗑️</button>
                            </form>
                        </div>
                    </li>
                <% }); %>
            <% } else { %>
                <div style="text-align: center; padding: 2rem 0;">
                    <span style="font-size: 2rem; opacity: 0.5;">📭</span>
                    <p style="color: var(--muted); margin-top: 10px;">Nessun servizio inserito.</p>
                </div>
            <% } %>
        </ul>
    </div>

    <div class="dashboard-box">
        <h2><span>✨</span> Nuovo Progetto Portfolio</h2>
        <form id="newProjectForm" action="/add-project" method="POST">
            <label>Titolo del progetto</label>
            <input type="text" name="title" placeholder="Es. Shooting Moda..." required>
            <label>Descrizione</label>
            <textarea name="description" rows="4" placeholder="Descrivi il lavoro svolto..." required></textarea>

            <label>Contenuti (Foto e Video)</label>
            <input type="file" id="projectImages" accept="image/*,video/*" multiple required>
            <small style="color: var(--accent); display: block; margin-top: 5px;">Seleziona foto o video. Verranno caricati e compressi automaticamente.</small>

            <button type="submit" id="submitProjectBtn" class="btn-submit">Pubblica Galleria</button>
        </form>
    </div>

    <div class="dashboard-box">
        <h2><span>🖼️</span> I Tuoi Lavori</h2>
        <ul class="project-list">
            <% if (typeof projects !== 'undefined' && projects.length > 0) { %>
                <% projects.forEach(function(project) { %>
                    <li class="project-item">
                        <span class="drag-handle">☰</span>
                        <div class="project-info">
                            <span class="project-title"><%= project.title %></span>
                            <span class="project-desc">
                                📷 <%= project.images.length %> Contenuti inseriti
                            </span>
                        </div>
                        <div class="project-actions">

                            <% if (project.images.length > 1) { %>
                                <div id="gallery-data-<%= project.id %>" style="display:none;"><%= JSON.stringify(project.images) %></div>
                                <button type="button" class="btn-action" onclick="openReorderModal('<%= project.id %>')" title="Scegli l'ordine e la copertina">🔄 Ordina</button>
                            <% } %>

                            <form action="/delete-project/<%= project.id %>" method="POST" style="display:inline;" onsubmit="return confirm('Eliminare definitivamente questo progetto e la sua galleria?');">
                                <button type="submit" class="btn-action btn-delete" title="Elimina">🗑️</button>
                            </form>
                        </div>
                    </li>
                <% }); %>
            <% } else { %>
                <div style="text-align: center; padding: 2rem 0;">
                    <span style="font-size: 2rem; opacity: 0.5;">📁</span>
                    <p style="color: var(--muted); margin-top: 10px;">Nessun progetto caricato.</p>
                </div>
            <% } %>
        </ul>
    </div>

</div>

<div id="reorderModal" class="reorder-modal">
    <div class="dashboard-box" style="max-width: 500px; width: 100%; position:relative; margin:0;">
        <span onclick="closeReorderModal()" style="position:absolute; right:20px; top:20px; cursor:pointer; font-size:1.8rem; color:var(--muted);">&times;</span>
        <h2><span>🔄</span> Ordine Galleria</h2>
        <p style="color:var(--muted); font-size:0.9rem; margin-bottom:20px;">Trascina gli elementi per riordinarli. <b>Il primo elemento in alto sarà la copertina del progetto.</b></p>

        <form id="reorderForm" method="POST">
            <ul class="media-list" id="mediaList">
            </ul>
            <input type="hidden" name="image_urls" id="reorderImageUrls">
            <button type="submit" class="btn-submit" onclick="saveReorder()">Salva Ordine</button>
        </form>
    </div>
</div>

<div id="editServiceModal" class="reorder-modal">
    <div class="dashboard-box" style="max-width: 500px; width: 100%; position:relative; margin:0;">
        <span onclick="closeEditServiceModal()" style="position:absolute; right:20px; top:20px; cursor:pointer; font-size:1.8rem; color:var(--muted);">&times;</span>
        <h2><span>✏️</span> Modifica Servizio</h2>

        <form id="editServiceForm" method="POST">
            <label>Nome Servizio</label>
            <input type="text" name="title" id="editServiceTitle" required>

            <label>Icona (Usa Emoji)</label>
            <input type="text" name="icon" id="editServiceIcon" required>

            <label>Tags (separati da virgola)</label>
            <input type="text" name="tags" id="editServiceTags">

            <label>Descrizione</label>
            <textarea name="description" rows="3" id="editServiceDesc" required></textarea>

            <button type="submit" class="btn-submit">Salva Modifiche</button>
        </form>
    </div>
</div>

<div class="nav-links">
    <a href="/">← Torna al sito web pubblico</a>
</div>

<script>
    const newProjectForm = document.getElementById('newProjectForm');
    const projectImages = document.getElementById('projectImages');
    const submitProjectBtn = document.getElementById('submitProjectBtn');

    const cloudName = "<%= typeof cloudName !== 'undefined' ? cloudName : '' %>";

    // CARICAMENTO DIRETTO NUOVI PROGETTI SU CLOUDINARY
    if (newProjectForm) {
        newProjectForm.addEventListener('submit', async (e) => {
            e.preventDefault();

            submitProjectBtn.innerText = 'Caricamento contenuti in corso... ⏳';
            submitProjectBtn.disabled = true;

            const files = projectImages.files;
            const uploadedUrls = [];

            try {
                for (let i = 0; i < files.length; i++) {
                    const formData = new FormData();
                    formData.append('file', files[i]);
                    formData.append('upload_preset', 'portfolio_upload');

                    const response = await fetch(`https://api.cloudinary.com/v1_1/${cloudName}/auto/upload`, {
                        method: 'POST',
                        body: formData
                    });

                    const data = await response.json();
                    if (data.secure_url) {
                        uploadedUrls.push(data.secure_url);
                    } else {
                        throw new Error(data.error.message);
                    }
                }

                const hiddenInput = document.createElement('input');
                hiddenInput.type = 'hidden';
                hiddenInput.name = 'image_urls';
                hiddenInput.value = JSON.stringify(uploadedUrls);
                newProjectForm.appendChild(hiddenInput);

                projectImages.value = '';
                newProjectForm.submit();

            } catch (error) {
                console.error(error);
                alert('Errore caricamento. Hai creato il preset "portfolio_upload" su Cloudinary impostato su Unsigned?');
                submitProjectBtn.innerText = 'Pubblica Galleria';
                submitProjectBtn.disabled = false;
            }
        });
    }

    // 🔴 NUOVO: LOGICA PER MODIFICA SERVIZI
    const editServiceModal = document.getElementById('editServiceModal');
    const editServiceForm = document.getElementById('editServiceForm');

    function openEditServiceModal(btn) {
        // Prendi i dati dai data-attribute del bottone premuto
        const id = btn.getAttribute('data-id');
        document.getElementById('editServiceTitle').value = btn.getAttribute('data-title');
        document.getElementById('editServiceIcon').value = btn.getAttribute('data-icon');
        document.getElementById('editServiceDesc').value = btn.getAttribute('data-desc');
        document.getElementById('editServiceTags').value = btn.getAttribute('data-tags');

        // Imposta l'azione del form verso l'ID corretto
        editServiceForm.action = `/edit-service/${id}`;
        editServiceModal.style.display = 'flex';
    }

    function closeEditServiceModal() {
        editServiceModal.style.display = 'none';
    }

    // LOGICA PER IL RIORDINO DEI MEDIA
    const reorderModal = document.getElementById('reorderModal');
    const mediaList = document.getElementById('mediaList');
    const reorderForm = document.getElementById('reorderForm');
    const reorderImageUrls = document.getElementById('reorderImageUrls');

    function openReorderModal(projectId) {
        reorderForm.action = `/reorder-media/${projectId}`;
        mediaList.innerHTML = '';

        const dataDiv = document.getElementById('gallery-data-' + projectId);
        const images = JSON.parse(dataDiv.innerText);

        images.forEach((url, index) => {
            const isVideo = url.match(/\.(mp4|webm|mov|ogg)$/i);
            let thumbUrl = url;
            if(isVideo) thumbUrl = url.replace(/\.[^/.]+$/, ".jpg");

            const li = document.createElement('li');
            li.className = 'media-item';
            li.draggable = true;
            li.dataset.url = url;

            const badgeCopertina = index === 0 ? `<span style="background:var(--accent); color:white; padding:2px 6px; border-radius:4px; font-size:0.6rem; font-weight:bold; margin-left:10px;">COPERTINA ATTUALE</span>` : '';
            const typeIcon = isVideo ? '🎥 Video' : '📷 Foto';

            li.innerHTML = `
                <span class="drag-handle" title="Trascina">☰</span>
                <img src="${thumbUrl}" class="media-thumbnail">
                <div style="flex-grow:1; display:flex; flex-direction:column; justify-content:center;">
                    <span style="font-size:0.85rem; color:var(--white);">${typeIcon} ${badgeCopertina}</span>
                </div>
            `;

            li.addEventListener('dragstart', () => li.classList.add('dragging'));
            li.addEventListener('dragend', () => li.classList.remove('dragging'));

            mediaList.appendChild(li);
        });

        reorderModal.style.display = 'flex';
    }

    function closeReorderModal() {
        reorderModal.style.display = 'none';
    }

    mediaList.addEventListener('dragover', (e) => {
        e.preventDefault();
        const afterElement = getDragAfterElementMedia(mediaList, e.clientY);
        const dragging = document.querySelector('.media-item.dragging');
        if (afterElement == null) {
            mediaList.appendChild(dragging);
        } else {
            mediaList.insertBefore(dragging, afterElement);
        }
    });

    function getDragAfterElementMedia(container, y) {
        const draggableElements = [...container.querySelectorAll('.media-item:not(.dragging)')];
        return draggableElements.reduce((closest, child) => {
            const box = child.getBoundingClientRect();
            const offset = y - box.top - box.height / 2;
            if (offset < 0 && offset > closest.offset) {
                return { offset: offset, element: child };
            } else {
                return closest;
            }
        }, { offset: Number.NEGATIVE_INFINITY }).element;
    }

    function saveReorder() {
        const items = [...mediaList.querySelectorAll('.media-item')];
        const newUrls = items.map(item => item.dataset.url);
        reorderImageUrls.value = JSON.stringify(newUrls);
    }
</script>

</body>
</html>