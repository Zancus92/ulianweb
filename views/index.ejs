<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ULiAN | Fotografia & Social Media</title>
    <meta name="description" content="Portfolio di ULiAN, servizi esclusivi di Fotografia & Gestione Social Media." />

    <style>
        /* =========================================
           VARIABILI E IMPOSTAZIONI DI BASE
           ========================================= */
        :root {
            --bg: #0a0a0d;
            --bg-soft: #121218;
            --card: rgba(255,255,255,0.05);
            --card-border: rgba(255,255,255,0.08);
            --text: #f5f5f7;
            --muted: #b7b7c0;
            --accent: #ff5f87; /* Rosa acceso */
            --accent-2: #ff7aa1;
            --gold: #ffd700;
            --white: #ffffff;
            --shadow: 0 20px 60px rgba(0,0,0,0.35);
            --radius: 24px;
            --max: 1200px;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }
        html { scroll-behavior: smooth; }
        body {
            font-family: 'Inter', ui-sans-serif, system-ui, -apple-system, sans-serif;
            background:
                    radial-gradient(circle at top right, rgba(255,95,135,0.12), transparent 25%),
                    radial-gradient(circle at bottom left, rgba(255,95,135,0.1), transparent 22%),
                    var(--bg);
            color: var(--text);
            line-height: 1.6;
            overflow-x: hidden;
        }
        a { color: inherit; text-decoration: none; }

        .noise {
            position: fixed; inset: 0; pointer-events: none; opacity: 0.035;
            background-image: radial-gradient(circle, #fff 0.8px, transparent 0.8px);
            background-size: 12px 12px; z-index: 1;
        }

        .cursor-glow {
            position: fixed; width: 300px; height: 300px; border-radius: 50%;
            background: radial-gradient(circle, rgba(255,95,135,0.18), transparent 65%);
            pointer-events: none; transform: translate(-50%, -50%); z-index: 0; filter: blur(18px);
        }

        /* =========================================
           HEADER E NAVIGAZIONE
           ========================================= */
        header {
            position: sticky; top: 0; z-index: 30; backdrop-filter: blur(14px);
            background: rgba(10,10,13,0.55); border-bottom: 1px solid rgba(255,255,255,0.06);
        }
        .nav {
            max-width: var(--max); margin: 0 auto; padding: 16px 20px;
            display: flex; align-items: center; justify-content: space-between; gap: 20px;
        }
        .brand { display: flex; align-items: center; gap: 14px; font-weight: 700; }
        .brand-text span { display: block; font-size: 0.8rem; color: var(--muted); font-weight: 500; }
        .nav-links { display: flex; gap: 18px; }
        .nav-links a { color: var(--muted); font-size: 0.95rem; transition: 0.25s ease; }
        .nav-links a:hover { color: var(--white); }

        /* =========================================
           COMPONENTI COMUNI
           ========================================= */
        .container { max-width: var(--max); margin: 0 auto; padding: 90px 20px; }
        .eyebrow {
            display: inline-flex; gap: 10px; align-items: center; padding: 10px 14px;
            border: 1px solid rgba(255,255,255,0.08); border-radius: 999px;
            background: rgba(255,255,255,0.03); color: var(--muted); margin-bottom: 22px; font-size: 0.92rem;
        }
        .eyebrow::before {
            content: ""; width: 8px; height: 8px; background: var(--accent);
            border-radius: 50%; box-shadow: 0 0 18px var(--accent);
        }
        .gradient-text {
            background: linear-gradient(135deg, #fff, #ff95b5, #ff5f87);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
        }
        .btn {
            display: inline-flex; align-items: center; justify-content: center; gap: 10px;
            padding: 14px 22px; border-radius: 999px; border: 1px solid rgba(255,255,255,0.08);
            transition: all 0.25s ease; font-weight: 700;
        }
        .btn-primary {
            background: linear-gradient(135deg, var(--accent), var(--accent-2)); border: none;
            box-shadow: 0 12px 30px rgba(255,95,135,0.25);
        }
        .btn:hover { transform: translateY(-3px); opacity: 0.9; }

        /* =========================================
           SEZIONE HERO
           ========================================= */
        .hero { min-height: 80vh; display: flex; align-items: center; }
        .hero-grid { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 40px; align-items: center; }
        h1 { font-size: clamp(2.6rem, 7vw, 5rem); line-height: 1.05; letter-spacing: -0.03em; margin-bottom: 22px; }
        .hero p { font-size: 1.08rem; color: var(--muted); max-width: 640px; margin-bottom: 30px; }
        .hero-card {
            position: relative; background: linear-gradient(180deg, rgba(255,255,255,0.08), rgba(255,255,255,0.03));
            border: 1px solid rgba(255,255,255,0.08); border-radius: 30px; padding: 28px;
            box-shadow: var(--shadow); overflow: hidden; transform-style: preserve-3d;
        }

        /* =========================================
           🔴 NUOVO: SEZIONE CHI SIAMO (STUDIO)
           ========================================= */
        .about-grid {
            display: grid;
            grid-template-columns: 0.9fr 1.1fr;
            gap: 60px;
            align-items: center;
        }
        .about-content h2 { font-size: clamp(2rem, 4vw, 3rem); line-height: 1.1; margin-bottom: 24px; }
        .about-content p { color: var(--muted); font-size: 1.1rem; margin-bottom: 20px; }

        .about-image-wrapper {
            position: relative;
            border-radius: 30px;
            padding: 10px;
            /* Bordo rosa coordinato alle card */
            border: 1px solid rgba(255, 95, 135, 0.3);
            background: rgba(255, 255, 255, 0.02);
        }
        .about-image-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 22px;
            display: block;
            filter: grayscale(20%);
            transition: filter 0.5s ease;
        }
        .about-image-wrapper:hover img { filter: grayscale(0%); }

        /* Elemento decorativo dinamico */
        .about-image-wrapper::after {
            content: "";
            position: absolute;
            -z-index: -1;
            top: 20px;
            left: -20px;
            width: 100%;
            height: 100%;
            border: 1px solid rgba(255, 95, 135, 0.1);
            border-radius: 30px;
            pointer-events: none;
        }

        /* =========================================
           SEZIONE PORTFOLIO (SISTEMATA)
           ========================================= */
        .section-head { margin-bottom: 40px; }
        .section-head h2 { font-size: clamp(2rem, 4vw, 3.4rem); letter-spacing: -0.04em; }
        .portfolio-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 24px; }

        .project {
            position: relative; min-height: 380px; border-radius: 28px; overflow: hidden;
            border: 1px solid rgba(255, 95, 135, 0.25); background-clip: padding-box;
            padding: 24px; display: flex; flex-direction: column; justify-content: end;
            transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
            background-size: cover; background-position: center; cursor: pointer;
        }
        .project:hover { transform: translateY(-8px); border-color: var(--accent); box-shadow: 0 20px 40px rgba(0,0,0,0.5); }
        .project::after {
            content: ""; position: absolute; inset: 0;
            background: linear-gradient(to bottom, rgba(10,10,13,0) 20%, rgba(10,10,13,0.85) 70%, rgba(10,10,13,1) 100%);
            z-index: 0;
        }
        .project > * { position: relative; z-index: 1; }
        .project h3 { font-size: 1.5rem; margin-bottom: 8px; color: var(--white); text-shadow: 0 2px 4px rgba(0,0,0,0.8); }
        .project p { color: #d8d8df; font-size: 0.95rem; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }

        /* =========================================
           MODAL, FOOTER E ALTRO
           ========================================= */
        .modal {
            display: none; position: fixed; z-index: 1000; left: 0; top: 0; width: 100%; height: 100%;
            background-color: rgba(0, 0, 0, 0.9); backdrop-filter: blur(10px);
            justify-content: center; align-items: center; opacity: 0; transition: opacity 0.3s ease;
        }
        .modal.show { display: flex; opacity: 1; }
        .modal-content {
            background: var(--bg-soft); border: 1px solid var(--card-border); border-radius: var(--radius);
            width: 90%; max-width: 900px; max-height: 90vh; overflow-y: auto; position: relative;
            transform: translateY(30px); transition: transform 0.3s ease;
        }
        .modal.show .modal-content { transform: translateY(0); }
        .close-modal {
            position: absolute; top: 20px; right: 25px; color: var(--muted); font-size: 35px; cursor: pointer;
            z-index: 10; background: rgba(0,0,0,0.5); width: 45px; height: 45px; border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
        }
        .modal-image { width: 100%; max-height: 60vh; object-fit: cover; border-bottom: 1px solid var(--card-border); }
        .modal-body { padding: 40px; }

        footer { border-top: 1px solid rgba(255,255,255,0.06); background: rgba(10,10,13,0.8); margin-top: 40px; }
        .footer-inner { max-width: var(--max); margin: 0 auto; padding: 28px 20px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; color: var(--muted); }

        .reveal { opacity: 0; transform: translateY(40px); transition: all 0.8s cubic-bezier(0.2, 1, 0.3, 1); }
        .reveal.visible { opacity: 1; transform: translateY(0); }

        @media (max-width: 800px) {
            .hero-grid, .about-grid { grid-template-columns: 1fr; gap: 40px; }
            .about-grid { display: flex; flex-direction: column-reverse; } /* Testo sopra immagine su mobile */
            h1 { font-size: 3rem; }
            .nav { flex-direction: column; }
        }
    </style>
</head>
<body>
<div class="noise"></div>
<div class="cursor-glow" id="cursorGlow"></div>

<header>
    <nav class="nav">
        <a href="/" class="brand">
            <div class="brand-text">
                <span style="color: var(--white); font-size: 1.2rem; font-weight: 800;">ULiAN</span>
                <span>Studio Visivo</span>
            </div>
        </a>
        <div class="nav-links">
            <a href="#home">Home</a>
            <a href="#about">Studio</a>
            <a href="#portfolio">Portfolio</a>
        </div>
    </nav>
</header>

<main>
    <section class="hero" id="home">
        <div class="container">
            <div class="hero-grid">
                <div class="reveal">
                    <div class="eyebrow">Fotografia & Social Media</div>
                    <h1>Contenuti <span class="gradient-text">visivi</span><br />che lasciano il segno.</h1>
                    <p>Servizi esclusivi di fotografia e direzione creativa per brand che puntano all'eccellenza.</p>
                    <a href="#portfolio" class="btn btn-primary">Esplora il Portfolio</a>
                </div>
                <div class="hero-card reveal" id="tiltCard">
                    <div class="mini-label">Servizi Esclusivi</div>
                    <h3>Creatività che comunica.</h3>
                    <p>Dal set fotografico alla strategia social: curo l'immagine del tuo brand a 360 gradi.</p>
                </div>
            </div>
        </div>
    </section>

    <section id="about">
        <div class="container">
            <div class="about-grid">
                <div class="about-image-wrapper reveal">
                    <img src="https://images.unsplash.com/photo-1492691523567-6170f2295b21?auto=format&fit=crop&q=80&w=800" alt="ULiAN Studio Interno">
                </div>
                <div class="about-content reveal">
                    <div class="eyebrow">L'Essenza dello Studio</div>
                    <h2>Oltre lo scatto, <br><span class="gradient-text">costruiamo identità.</span></h2>
                    <p>
                        ULiAN nasce dalla necessità di unire l'arte della fotografia tradizionale alle dinamiche veloci dei nuovi media. Non ci limitiamo a "fare foto", ma progettiamo il modo in cui il mondo percepisce il tuo brand.
                    </p>
                    <p>
                        Ogni progetto è un pezzo unico, curato con un approccio sartoriale dove la luce e la composizione diventano strumenti strategici di marketing.
                    </p>
                    <a href="#portfolio" class="btn">Scopri il metodo</a>
                </div>
            </div>
        </div>
    </section>

    <section id="portfolio">
        <div class="container">
            <div class="section-head reveal">
                <div class="eyebrow">Lavori Selezionati</div>
                <h2>Il mio Portfolio.</h2>
            </div>

            <div class="portfolio-grid">
                <% if (typeof projects !== 'undefined' && projects.length === 0) { %>
                    <div class="empty-msg reveal">Nessun progetto presente.</div>
                <% } else if (typeof projects !== 'undefined') { %>
                    <% projects.forEach(function(project, index) { %>
                        <article class="project reveal"
                                 style="background-image: url('<%= project.image_url %>'); transition-delay: <%= (index % 3) * 0.1 %>s"
                                 onclick="openModal('<%= project.title.replace(/'/g, "\\'") %>', '<%= project.description.replace(/'/g, "\\'").replace(/\n/g, "\\n") %>', '<%= project.image_url %>')">
                            <% if (project.featured) { %><div class="badge-featured">⭐ In Evidenza</div><% } %>
                            <h3><%= project.title %></h3>
                            <p><%= project.description %></p>
                        </article>
                    <% }); %>
                <% } %>
            </div>
        </div>
    </section>
</main>

<div id="projectModal" class="modal">
    <div class="modal-content">
        <span class="close-modal" onclick="closeModal()">&times;</span>
        <img id="modalImg" class="modal-image" src="" alt="Progetto">
        <div class="modal-body">
            <h2 id="modalTitle" class="modal-title"></h2>
            <p id="modalDesc" class="modal-desc"></p>
        </div>
    </div>
</div>

<footer>
    <div class="footer-inner">
        <div>© 2026 ULiAN Studio.</div>
        <a href="/login" class="admin-link">⚙️ Accesso Amministratore</a>
    </div>
</footer>

<script>
    // 1. Reveal Animation
    const reveals = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => { if (entry.isIntersecting) entry.target.classList.add('visible'); });
    }, { threshold: 0.15 });
    reveals.forEach(el => observer.observe(el));

    // 2. Cursor Glow
    const glow = document.getElementById('cursorGlow');
    window.addEventListener('mousemove', (e) => {
        glow.style.left = e.clientX + 'px'; glow.style.top = e.clientY + 'px';
    });

    // 3. Tilt Card
    const tiltCard = document.getElementById('tiltCard');
    tiltCard.addEventListener('mousemove', (e) => {
        const rect = tiltCard.getBoundingClientRect();
        const x = e.clientX - rect.left; const y = e.clientY - rect.top;
        const rotateY = ((x / rect.width) - 0.5) * 12; const rotateX = ((y / rect.height) - 0.5) * -12;
        tiltCard.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg)`;
    });
    tiltCard.addEventListener('mouseleave', () => { tiltCard.style.transform = 'perspective(1000px) rotateX(0deg) rotateY(0deg)'; });

    // 4. Modal Logic
    const modal = document.getElementById("projectModal");
    function openModal(title, description, imageUrl) {
        document.getElementById("modalTitle").innerText = title;
        document.getElementById("modalDesc").innerText = description;
        document.getElementById("modalImg").src = imageUrl;
        modal.classList.add("show"); document.body.style.overflow = "hidden";
    }
    function closeModal() {
        modal.classList.remove("show"); document.body.style.overflow = "auto";
        setTimeout(() => { document.getElementById("modalImg").src = ""; }, 300);
    }
    window.onclick = (e) => { if (e.target == modal) closeModal(); }
</script>
</body>
</html>