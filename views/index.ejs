<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>ULiAN | Fotografia & Social Media</title>
    <meta name="description" content="Portfolio di ULiAN, servizi esclusivi di Fotografia & Gestione Social Media." />

    <style>
        :root {
            --bg: #0a0a0d; --bg-soft: #121218; --card: rgba(255,255,255,0.05);
            --card-border: rgba(255,255,255,0.08); --text: #f5f5f7; --muted: #b7b7c0;
            --accent: #ff5f87; --accent-2: #ff7aa1; --gold: #ffd700; --white: #ffffff;
            --shadow: 0 20px 60px rgba(0,0,0,0.35); --radius: 24px; --max: 1200px;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }
        html { scroll-behavior: smooth; }
        body { font-family: 'Inter', ui-sans-serif, system-ui, -apple-system, sans-serif; background: radial-gradient(circle at top right, rgba(255,95,135,0.12), transparent 25%), radial-gradient(circle at bottom left, rgba(255,95,135,0.1), transparent 22%), var(--bg); color: var(--text); line-height: 1.6; overflow-x: hidden; -webkit-font-smoothing: antialiased; }
        a { color: inherit; text-decoration: none; }
        button, a, .project, .close-modal, .slider-btn { touch-action: manipulation; }

        .noise { position: fixed; inset: 0; pointer-events: none; opacity: 0.035; background-image: radial-gradient(circle, #fff 0.8px, transparent 0.8px); background-size: 12px 12px; z-index: 1; }
        .cursor-glow { display: none; position: fixed; width: 300px; height: 300px; border-radius: 50%; background: radial-gradient(circle, rgba(255,95,135,0.18), transparent 65%); pointer-events: none; transform: translate(-50%, -50%); z-index: 0; filter: blur(18px); }
        #progress-bar { position: fixed; top: 0; left: 0; width: 0%; height: 3px; background: linear-gradient(90deg, var(--accent), var(--gold)); z-index: 9999; transition: width 0.1s ease; }

        header { position: sticky; top: 0; z-index: 50; backdrop-filter: blur(14px); background: rgba(10,10,13,0.75); border-bottom: 1px solid rgba(255,255,255,0.06); transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1); }
        header.hide { transform: translateY(-100%); }
        .nav { max-width: var(--max); margin: 0 auto; padding: 16px 20px; display: flex; align-items: center; justify-content: space-between; gap: 20px; position: relative; z-index: 60; }
        .brand { display: flex; align-items: center; gap: 14px; font-weight: 700; z-index: 60; }
        .brand-text span { display: block; font-size: 0.8rem; color: var(--muted); font-weight: 500; }
        .nav-links { display: flex; gap: 18px; }
        .nav-links a { color: var(--muted); font-size: 0.95rem; transition: 0.25s ease; position: relative; padding: 5px 0; }
        .nav-links a:hover { color: var(--white); }
        .nav-links a::after { content: ''; position: absolute; width: 0; height: 2px; bottom: 0; left: 0; background-color: var(--accent); transition: width 0.3s ease; }
        .nav-links a:hover::after { width: 100%; }
        .hamburger { display: none; flex-direction: column; gap: 6px; cursor: pointer; z-index: 60; background: transparent; border: none; padding: 10px; }
        .hamburger span { display: block; width: 28px; height: 2px; background-color: var(--white); transition: transform 0.3s ease, opacity 0.3s ease; border-radius: 2px; }

        .container { max-width: var(--max); margin: 0 auto; padding: 90px 20px; }
        .eyebrow { display: inline-flex; gap: 10px; align-items: center; padding: 10px 14px; border: 1px solid rgba(255,255,255,0.08); border-radius: 999px; background: rgba(255,255,255,0.03); color: var(--muted); margin-bottom: 22px; font-size: 0.92rem; }
        .eyebrow::before { content: ""; width: 8px; height: 8px; background: var(--accent); border-radius: 50%; box-shadow: 0 0 18px var(--accent); }
        .gradient-text { background: linear-gradient(135deg, #fff, #ff95b5, #ff5f87); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
        .btn { display: inline-flex; align-items: center; justify-content: center; gap: 10px; padding: 14px 22px; border-radius: 999px; border: 1px solid rgba(255,255,255,0.08); font-weight: 700; cursor: pointer; transition: transform 0.3s, opacity 0.3s; }
        .btn-primary { background: linear-gradient(135deg, var(--accent), var(--accent-2)); border: none; box-shadow: 0 12px 30px rgba(255,95,135,0.25); }
        .btn:hover { opacity: 0.9; }

        .hero { min-height: 80vh; display: flex; align-items: center; position: relative; }
        .hero-grid { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 40px; align-items: center; width: 100%; }
        h1 { font-size: clamp(2.5rem, 8vw, 5rem); line-height: 1.1; letter-spacing: -0.03em; margin-bottom: 22px; }
        .hero p { font-size: 1.08rem; color: var(--muted); max-width: 640px; margin-bottom: 30px; }
        .hero-card { position: relative; background: linear-gradient(180deg, rgba(255,255,255,0.08), rgba(255,255,255,0.03)); border: 1px solid rgba(255,255,255,0.08); border-radius: 30px; padding: 28px; box-shadow: var(--shadow); overflow: hidden; transform-style: preserve-3d; }
        .scroll-down { position: absolute; bottom: 30px; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; gap: 8px; color: var(--muted); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; opacity: 0.7; pointer-events: none; }
        .mouse-icon { width: 22px; height: 34px; border: 2px solid var(--muted); border-radius: 20px; position: relative; }
        .mouse-wheel { width: 4px; height: 6px; background: var(--accent); border-radius: 2px; position: absolute; top: 6px; left: 50%; transform: translateX(-50%); animation: scrollWheel 1.5s infinite; }
        @keyframes scrollWheel { 0% { top: 6px; opacity: 1; } 100% { top: 18px; opacity: 0; } }

        .about-grid { display: grid; grid-template-columns: 0.9fr 1.1fr; gap: 60px; align-items: center; }
        .about-content h2 { font-size: clamp(2rem, 5vw, 3rem); line-height: 1.1; margin-bottom: 24px; }
        .about-content p { color: var(--muted); font-size: 1.05rem; margin-bottom: 24px; }
        .about-image-wrapper { position: relative; border-radius: 30px; padding: 10px; border: 1px solid rgba(255, 95, 135, 0.3); background: rgba(255, 255, 255, 0.02); }
        .about-image-wrapper img { width: 100%; height: 100%; object-fit: cover; border-radius: 22px; display: block; filter: grayscale(20%); transition: filter 0.5s ease; }
        .about-image-wrapper:hover img { filter: grayscale(0%); }
        .about-image-wrapper::after { content: ""; position: absolute; z-index: -1; top: 20px; left: -20px; width: 100%; height: 100%; border: 1px solid rgba(255, 95, 135, 0.1); border-radius: 30px; pointer-events: none; }

        .section-head { margin-bottom: 40px; }
        .section-head h2 { font-size: clamp(2rem, 5vw, 3.4rem); letter-spacing: -0.04em; }

        .services-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px; }
        .service-card { background: linear-gradient(180deg, rgba(255,255,255,0.05), rgba(255,255,255,0.01)); border: 1px solid rgba(255,255,255,0.08); border-radius: var(--radius); padding: 35px 30px; position: relative; overflow: hidden; transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1); display: flex; flex-direction: column; }
        @media (hover: hover) and (pointer: fine) { .service-card:hover { transform: translateY(-8px); border-color: rgba(255, 95, 135, 0.4); box-shadow: 0 15px 35px rgba(0,0,0,0.4); } .service-card:hover .service-arrow { transform: translate(5px, -5px); color: var(--accent); } }
        .service-num { position: absolute; top: 20px; right: 25px; font-size: 4rem; font-weight: 800; color: rgba(255,255,255,0.04); line-height: 1; pointer-events: none; }
        .service-icon { font-size: 2.5rem; margin-bottom: 20px; }
        .service-name { font-size: 1.5rem; color: var(--white); margin-bottom: 15px; font-weight: 700; }
        .service-desc { color: var(--muted); font-size: 0.95rem; margin-bottom: 25px; flex-grow: 1; }
        .service-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 10px; position: relative; z-index: 2; }
        .service-tags .tag { font-size: 0.75rem; padding: 5px 12px; border-radius: 999px; background: rgba(255,95,135,0.08); color: var(--accent); border: 1px solid rgba(255,95,135,0.2); font-weight: 600; }
        .service-arrow { position: absolute; bottom: 30px; right: 30px; font-size: 1.2rem; color: var(--muted); transition: transform 0.3s, color 0.3s; }

        .portfolio-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; }
        .project { position: relative; min-height: 350px; border-radius: 24px; overflow: hidden; border: 1px solid rgba(255, 95, 135, 0.25); background-clip: padding-box; padding: 24px; display: flex; flex-direction: column; justify-content: end; transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1); background-size: cover; background-position: center; cursor: pointer; }
        @media (hover: hover) and (pointer: fine) { .project:hover { transform: translateY(-8px); border-color: var(--accent); box-shadow: 0 20px 40px rgba(0,0,0,0.5); } }
        .project::after { content: ""; position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(10,10,13,0) 20%, rgba(10,10,13,0.85) 70%, rgba(10,10,13,1) 100%); z-index: 0; }
        .project > * { position: relative; z-index: 1; }
        .project h3 { font-size: 1.4rem; margin-bottom: 8px; color: var(--white); text-shadow: 0 2px 4px rgba(0,0,0,0.8); }
        .project p { color: #d8d8df; font-size: 0.9rem; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }

        /* 🔴 NUOVO: Indicatore Galleria sulla Card */
        .gallery-indicator {
            position: absolute; top: 18px; left: 18px; z-index: 2;
            background: rgba(0,0,0,0.6); backdrop-filter: blur(8px);
            color: var(--white); padding: 5px 12px; border-radius: 20px;
            font-size: 0.75rem; font-weight: 600; display: flex; align-items: center; gap: 6px;
            border: 1px solid rgba(255,255,255,0.1);
        }
        .gallery-dots { display: flex; gap: 3px; }
        .gallery-dots span { width: 4px; height: 4px; background: var(--white); border-radius: 50%; }

        /* MODAL E SLIDER */
        .modal { display: none; position: fixed; z-index: 1000; left: 0; top: 0; width: 100%; height: 100%; background-color: rgba(0, 0, 0, 0.9); backdrop-filter: blur(10px); justify-content: center; align-items: center; opacity: 0; transition: opacity 0.3s ease; padding: 15px; }
        .modal.show { display: flex; opacity: 1; }
        .modal-content { background: var(--bg-soft); border: 1px solid var(--card-border); border-radius: var(--radius); width: 100%; max-width: 900px; max-height: 90vh; overflow-y: auto; position: relative; transform: translateY(30px); transition: transform 0.4s cubic-bezier(0.2, 1, 0.3, 1); }
        .modal.show .modal-content { transform: translateY(0); }
        .close-modal { position: absolute; top: 15px; right: 15px; color: var(--white); font-size: 30px; cursor: pointer; z-index: 100; background: rgba(0,0,0,0.6); width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; transition: all 0.2s; backdrop-filter: blur(5px); }
        @media (hover: hover) and (pointer: fine) { .close-modal:hover { background: var(--accent); transform: scale(1.1); } }

        /* 🔴 NUOVO: Area Immagine e controlli slider */
        .modal-img-container { position: relative; width: 100%; background: #000; display: flex; justify-content: center; align-items: center; border-top-left-radius: var(--radius); border-top-right-radius: var(--radius); }
        .modal-image { max-width: 100%; max-height: 60vh; object-fit: contain; }
        .slider-btn { position: absolute; top: 50%; transform: translateY(-50%); background: rgba(0,0,0,0.5); color: white; border: none; width: 40px; height: 40px; border-radius: 50%; font-size: 1.2rem; cursor: pointer; backdrop-filter: blur(5px); transition: all 0.2s; display: none; align-items: center; justify-content: center; z-index: 10;}
        .slider-btn:hover { background: var(--accent); }
        .slider-btn.prev { left: 15px; }
        .slider-btn.next { right: 15px; }
        .slider-counter { position: absolute; bottom: 15px; right: 15px; background: rgba(0,0,0,0.6); color: white; padding: 4px 10px; border-radius: 15px; font-size: 0.8rem; display: none; z-index: 10; backdrop-filter: blur(5px);}

        .modal-body { padding: 30px; }
        footer { border-top: 1px solid rgba(255,255,255,0.06); background: rgba(10,10,13,0.8); margin-top: 40px; }
        .footer-inner { max-width: var(--max); margin: 0 auto; padding: 28px 20px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; color: var(--muted); gap: 15px;}
        .reveal { opacity: 0; transform: translateY(40px); transition: all 0.8s cubic-bezier(0.2, 1, 0.3, 1); }
        .reveal.visible { opacity: 1; transform: translateY(0); }

        @media (max-width: 800px) {
            .hamburger { display: flex; } .nav { padding: 15px 20px; }
            .nav-links { position: fixed; top: 0; left: 0; width: 100%; height: 100vh; background: rgba(10, 10, 13, 0.98); backdrop-filter: blur(15px); flex-direction: column; justify-content: center; align-items: center; gap: 40px; transform: translateY(-100%); opacity: 0; visibility: hidden; transition: all 0.4s cubic-bezier(0.25, 1, 0.5, 1); z-index: 55; }
            .nav-links.active { transform: translateY(0); opacity: 1; visibility: visible; }
            .nav-links a { font-size: 2rem; }
            .hamburger.active span:nth-child(1) { transform: translateY(8px) rotate(45deg); }
            .hamburger.active span:nth-child(2) { opacity: 0; }
            .hamburger.active span:nth-child(3) { transform: translateY(-8px) rotate(-45deg); }
            .container { padding: 50px 15px; } .hero { min-height: auto; padding-top: 40px; }
            .hero-grid, .about-grid { grid-template-columns: 1fr; gap: 35px; } .about-grid { display: flex; flex-direction: column-reverse; }
            h1 { font-size: 2.6rem; text-align: center; } .hero p { text-align: center; margin: 0 auto 25px auto; font-size: 1.05rem; }
            .hero .reveal { display: flex; flex-direction: column; align-items: center; } .scroll-down { display: none; }
            .about-content { text-align: center; } .about-image-wrapper::after { top: 10px; left: -10px; }
            .section-head { text-align: center; } .section-head p { margin: 0 auto; } .eyebrow { margin: 0 auto 15px auto; }
            .modal-body { padding: 20px; } .modal-title { font-size: 1.8rem; margin-bottom: 10px;} .modal-desc { font-size: 0.95rem; }
            .footer-inner { flex-direction: column; text-align: center; }
        }
    </style>
</head>
<body>
<div id="progress-bar"></div>
<div class="noise"></div>
<div class="cursor-glow" id="cursorGlow"></div>

<header id="main-header">
    <nav class="nav">
        <a href="/" class="brand">
            <div class="brand-text">
                <span style="color: var(--white); font-size: 1.2rem; font-weight: 800;">ULiAN</span>
                <span>Studio Visivo</span>
            </div>
        </a>
        <button class="hamburger" id="hamburger" aria-label="Menu"><span></span><span></span><span></span></button>
        <div class="nav-links" id="nav-links">
            <a href="#home">Home</a>
            <a href="#about">Studio</a>
            <a href="#servizi">Servizi</a>
            <a href="#portfolio">Portfolio</a>
        </div>
    </nav>
</header>

<main>
    <section class="hero" id="home">
        <div class="container">
            <div class="hero-grid">
                <div class="reveal">
                    <div class="eyebrow">Fotografia & Social Media</div>
                    <h1>Contenuti <span class="gradient-text">visivi</span><br />che lasciano il segno.</h1>
                    <p>Servizi esclusivi di fotografia e direzione creativa per brand che puntano all'eccellenza.</p>
                    <a href="#portfolio" class="btn btn-primary magnetic">Esplora il Portfolio</a>
                </div>
                <div class="hero-card reveal" id="tiltCard">
                    <div class="mini-label">Servizi Esclusivi</div>
                    <h3>Creatività che comunica.</h3>
                    <p>Dal set fotografico alla strategia social: curo l'immagine del tuo brand a 360 gradi.</p>
                </div>
            </div>
        </div>
        <div class="scroll-down"><span>Scroll</span><div class="mouse-icon"><div class="mouse-wheel"></div></div></div>
    </section>

    <section id="about">
        <div class="container">
            <div class="about-grid">
                <div class="about-image-wrapper reveal">
                    <img src="<%= typeof about !== 'undefined' && about.image_url ? about.image_url : 'https://images.unsplash.com/photo-1554046920-90dc20696352?q=80&w=800&auto=format&fit=crop' %>" alt="ULiAN Studio">
                </div>
                <div class="about-content reveal">
                    <div class="eyebrow">L'Essenza dello Studio</div>
                    <h2><%= typeof about !== 'undefined' && about.title ? about.title : 'Costruiamo Identità Memorabili' %></h2>
                    <p style="white-space: pre-wrap;"><%= typeof about !== 'undefined' && about.description ? about.description : 'Il mio obiettivo è creare un linguaggio visivo unico.' %></p>
                    <a href="#portfolio" class="btn magnetic">Scopri i lavori</a>
                </div>
            </div>
        </div>
    </section>

    <section id="servizi">
        <div class="container">
            <div class="section-head reveal">
                <div>
                    <div class="eyebrow">Cosa facciamo</div>
                    <h2>I Nostri<br>Servizi</h2>
                </div>
                <p>Dalla pre-produzione al lancio online, copriamo ogni fase con cura artigianale e tecnologia d'avanguardia.</p>
            </div>
            <div class="services-grid">
                <% if (typeof services !== 'undefined' && services.length > 0) { %>
                    <% services.forEach(function(service, index) { %>
                        <div class="service-card reveal" style="transition-delay: <%= (index % 4) * 0.1 %>s;">
                            <div class="service-num">0<%= index + 1 %></div>
                            <div class="service-icon"><%= service.icon %></div>
                            <h3 class="service-name"><%= service.title %></h3>
                            <p class="service-desc"><%= service.description %></p>
                            <div class="service-tags">
                                <% if (service.tags) { %>
                                    <% service.tags.split(',').forEach(tag => { %>
                                        <span class="tag"><%= tag.trim() %></span>
                                    <% }); %>
                                <% } %>
                            </div>
                            <div class="service-arrow">↗</div>
                        </div>
                    <% }); %>
                <% } %>
            </div>
        </div>
    </section>

    <section id="portfolio">
        <div class="container">
            <div class="section-head reveal">
                <div>
                    <div class="eyebrow">Lavori Selezionati</div>
                    <h2>Il mio Portfolio.</h2>
                </div>
            </div>

            <div class="portfolio-grid">
                <% if (typeof projects !== 'undefined' && projects.length > 0) { %>
                    <% projects.forEach(function(project, index) { %>
                        <article class="project reveal"
                                 style="background-image: url('<%= project.images[0] %>'); transition-delay: <%= (index % 3) * 0.1 %>s"
                                 data-title="<%= project.title %>"
                                 data-desc="<%= project.description %>"
                                 data-images='<%= JSON.stringify(project.images) %>'
                                 onclick="openModal(this)">

                            <% if (project.featured) { %><div class="badge-featured">⭐ In Evidenza</div><% } %>

                            <% if (project.images.length > 1) { %>
                                <div class="gallery-indicator">
                                    <div class="gallery-dots"><span></span><span></span><span></span></div>
                                    <%= project.images.length %> Foto
                                </div>
                            <% } %>

                            <h3><%= project.title %></h3>
                            <p><%= project.description %></p>
                        </article>
                    <% }); %>
                <% } else { %>
                    <div class="empty-msg reveal">Nessun progetto presente.</div>
                <% } %>
            </div>
        </div>
    </section>
</main>

<div id="projectModal" class="modal">
    <div class="modal-content">
        <span class="close-modal" onclick="closeModal()">&times;</span>

        <div class="modal-img-container">
            <button class="slider-btn prev" id="btnPrev" onclick="changeSlide(-1)">❮</button>
            <img id="modalImg" class="modal-image" src="" alt="Progetto">
            <button class="slider-btn next" id="btnNext" onclick="changeSlide(1)">❯</button>
            <div class="slider-counter" id="sliderCounter">1 / 1</div>
        </div>

        <div class="modal-body">
            <h2 id="modalTitle" class="modal-title"></h2>
            <p id="modalDesc" class="modal-desc"></p>
        </div>
    </div>
</div>

<footer>
    <div class="footer-inner">
        <div>© 2026 ULiAN Studio. Tutti i diritti riservati.</div>
        <a href="/login" class="admin-link magnetic">⚙️ Accesso Amministratore</a>
    </div>
</footer>

<script>
    const isTouchDevice = ('ontouchstart' in window) || (navigator.maxTouchPoints > 0) || (window.matchMedia("(pointer: coarse)").matches);
    const hamburger = document.getElementById('hamburger');
    const navLinksMenu = document.getElementById('nav-links');
    const navItems = document.querySelectorAll('.nav-links a');

    if (hamburger) {
        hamburger.addEventListener('click', () => {
            hamburger.classList.toggle('active'); navLinksMenu.classList.toggle('active');
            if(navLinksMenu.classList.contains('active')) document.body.style.overflow = 'hidden';
            else document.body.style.overflow = 'auto';
        });
        navItems.forEach(item => { item.addEventListener('click', () => { hamburger.classList.remove('active'); navLinksMenu.classList.remove('active'); document.body.style.overflow = 'auto'; }); });
    }

    const reveals = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver((entries) => { entries.forEach(entry => { if (entry.isIntersecting) entry.target.classList.add('visible'); }); }, { threshold: 0.15 });
    reveals.forEach(el => observer.observe(el));

    // 🔴 NUOVO: LOGICA SLIDER MODAL
    const modal = document.getElementById("projectModal");
    let currentGallery = [];
    let currentIndex = 0;

    function openModal(cardElement) {
        // Legge i dati nascosti nella card
        const title = cardElement.getAttribute('data-title');
        const description = cardElement.getAttribute('data-desc');
        currentGallery = JSON.parse(cardElement.getAttribute('data-images'));
        currentIndex = 0;

        document.getElementById("modalTitle").innerText = title;
        document.getElementById("modalDesc").innerText = description;
        updateSliderView();

        modal.classList.add("show");
        document.body.style.overflow = "hidden";
    }

    function changeSlide(direction) {
        currentIndex += direction;
        // Effetto Loop (se vai oltre l'ultima torna alla prima e viceversa)
        if (currentIndex >= currentGallery.length) currentIndex = 0;
        if (currentIndex < 0) currentIndex = currentGallery.length - 1;
        updateSliderView();
    }

    function updateSliderView() {
        const imgElement = document.getElementById("modalImg");
        imgElement.style.opacity = '0.5'; // Piccolo effetto visivo
        setTimeout(() => {
            imgElement.src = currentGallery[currentIndex];
            imgElement.style.opacity = '1';
        }, 50);

        // Mostra le frecce e il contatore solo se c'è più di 1 foto
        const showControls = currentGallery.length > 1 ? 'flex' : 'none';
        document.getElementById("btnPrev").style.display = showControls;
        document.getElementById("btnNext").style.display = showControls;
        document.getElementById("sliderCounter").style.display = showControls;
        document.getElementById("sliderCounter").innerText = `${currentIndex + 1} / ${currentGallery.length}`;
    }

    function closeModal() {
        modal.classList.remove("show"); document.body.style.overflow = "auto";
        setTimeout(() => { document.getElementById("modalImg").src = ""; }, 300);
    }

    // Chiude cliccando fuori o sulle frecce della tastiera
    window.onclick = (e) => { if (e.target == modal) closeModal(); }
    document.addEventListener('keydown', (e) => {
        if (!modal.classList.contains('show')) return;
        if (e.key === "Escape") closeModal();
        if (e.key === "ArrowRight") changeSlide(1);
        if (e.key === "ArrowLeft") changeSlide(-1);
    });

    window.addEventListener('scroll', () => {
        const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
        const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
        document.getElementById("progress-bar").style.width = ((winScroll / height) * 100) + "%";
    });

    let lastScrollTop = 0;
    const header = document.getElementById('main-header');
    window.addEventListener('scroll', () => {
        let scrollTop = window.pageYOffset || document.documentElement.scrollTop;
        if (scrollTop > lastScrollTop && scrollTop > 100 && !navLinksMenu.classList.contains('active')) header.classList.add('hide');
        else header.classList.remove('hide');
        lastScrollTop = scrollTop;
    });

    if (!isTouchDevice) {
        const glow = document.getElementById('cursorGlow'); glow.style.display = 'block';
        window.addEventListener('mousemove', (e) => { glow.style.left = e.clientX + 'px'; glow.style.top = e.clientY + 'px'; });

        const tiltCard = document.getElementById('tiltCard');
        if(tiltCard){
            tiltCard.addEventListener('mousemove', (e) => {
                const rect = tiltCard.getBoundingClientRect(); const x = e.clientX - rect.left; const y = e.clientY - rect.top;
                const rotateY = ((x / rect.width) - 0.5) * 12; const rotateX = ((y / rect.height) - 0.5) * -12;
                tiltCard.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg)`;
            });
            tiltCard.addEventListener('mouseleave', () => { tiltCard.style.transform = 'perspective(1000px) rotateX(0deg) rotateY(0deg)'; });
        }
        const magnets = document.querySelectorAll('.magnetic');
        magnets.forEach(btn => {
            btn.addEventListener('mousemove', (e) => {
                btn.style.transition = 'none'; const rect = btn.getBoundingClientRect();
                const x = (e.clientX - rect.left - rect.width / 2) * 0.3; const y = (e.clientY - rect.top - rect.height / 2) * 0.3;
                btn.style.transform = `translate(${x}px, ${y}px)`;
            });
            btn.addEventListener('mouseleave', () => { btn.style.transition = 'transform 0.4s cubic-bezier(0.2, 1, 0.3, 1)'; btn.style.transform = `translate(0px, 0px)`; });
        });
    }
</script>
</body>
</html>