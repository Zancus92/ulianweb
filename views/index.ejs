<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ULiAN | Portfolio</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
        /* Stili Generali */
        body {
            font-family: 'Poppins', sans-serif;
            margin: 0;
            padding: 0;
            background-color: #f4f4f9;
        }
        header {
            text-align: center;
            padding: 4rem 2rem;
            background: #111;
            color: white;
        }
        header h1 { margin: 0; font-size: 2.5rem; }

        /* Griglia del Portfolio */
        .portfolio-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 20px;
            padding: 40px;
            max-width: 1200px;
            margin: auto;
        }

        /* 1. LA CARD CON IL GRADIENTE NERO */
        .project-card {
            position: relative;
            border-radius: 12px;
            overflow: hidden;
            cursor: pointer;
            height: 350px; /* Altezza fissa per farle tutte uguali */
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
            transition: transform 0.3s ease;
        }
        .project-card:hover {
            transform: scale(1.03); /* Effetto zoom quando ci passi sopra col mouse */
        }
        .project-card img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }
        .project-overlay {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 60%; /* Il gradiente copre il 60% inferiore dell'immagine */
            /* Questa è la riga magica del gradiente: dal nero quasi solido in basso al trasparente in alto */
            background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0) 100%);
            display: flex;
            align-items: flex-end;
            padding: 20px;
            box-sizing: border-box;
        }
        .project-overlay h3 {
            color: white;
            margin: 0;
            font-size: 1.5rem;
        }

        /* 2. LA FINESTRA A COMPARSA (MODAL) A TUTTA PAGINA */
        .modal {
            display: none; /* Inizialmente è nascosta */
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.85); /* Sfondo nero semitrasparente dietro la finestra */
            z-index: 1000;
            justify-content: center;
            align-items: center;
            padding: 20px;
            box-sizing: border-box;
        }
        .modal-content {
            background: white;
            border-radius: 12px;
            max-width: 800px;
            width: 100%;
            max-height: 90vh;
            overflow-y: auto; /* Permette di scorrere se la descrizione è molto lunga */
            position: relative;
            display: flex;
            flex-direction: column;
            animation: fadeIn 0.3s ease; /* Piccola animazione di entrata */
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .modal-close {
            position: absolute;
            top: 15px;
            right: 20px;
            font-size: 2rem;
            color: white;
            cursor: pointer;
            background: #111;
            border-radius: 50%;
            width: 40px;
            height: 40px;
            display: flex;
            justify-content: center;
            align-items: center;
            box-shadow: 0 2px 5px rgba(0,0,0,0.3);
        }
        .modal-image {
            width: 100%;
            height: 400px;
            object-fit: cover;
            border-top-left-radius: 12px;
            border-top-right-radius: 12px;
        }
        .modal-text {
            padding: 30px;
        }
        .modal-text h2 {
            margin-top: 0;
            font-size: 2rem;
            color: #111;
        }
        .modal-text p {
            line-height: 1.8;
            color: #444;
            font-size: 1.05rem;
            white-space: pre-wrap; /* Mantiene gli "a capo" della tua descrizione */
        }
    </style>
</head>
<body>

<header>
    <h1>ULiAN Portfolio</h1>
    <p>I miei lavori e le mie passioni</p>
</header>

<div class="portfolio-grid">
    <% if (typeof projects !== 'undefined' && projects.length > 0) { %>
        <% projects.forEach(function(project) { %>
            <div class="project-card"
                 data-title="<%= project.title %>"
                 data-desc="<%= project.description %>"
                 data-img="<%= project.image_url %>"
                 onclick="openModal(this)">

                <img src="<%= project.image_url %>" alt="<%= project.title %>">

                <div class="project-overlay">
                    <h3><%= project.title %></h3>
                </div>
            </div>
        <% }); %>
    <% } else { %>
        <p style="text-align: center; grid-column: 1 / -1;">Nessun progetto pubblicato al momento.</p>
    <% } %>
</div>

<div id="projectModal" class="modal" onclick="closeModalOnOutsideClick(event)">
    <div class="modal-content">
        <span class="modal-close" onclick="closeModal()">&times;</span>
        <img id="modalImage" class="modal-image" src="" alt="Dettaglio Progetto">
        <div class="modal-text">
            <h2 id="modalTitle">Titolo</h2>
            <p id="modalDescription">Descrizione...</p>
        </div>
    </div>
</div>

<script>
    // Funzione per APRIRE la finestra a tutta pagina
    function openModal(cardElement) {
        // 1. Leggiamo i dati nascosti nella card che abbiamo cliccato
        const title = cardElement.getAttribute('data-title');
        const description = cardElement.getAttribute('data-desc');
        const imageUrl = cardElement.getAttribute('data-img');

        // 2. Inseriamo i dati letti all'interno della finestra pop-up
        document.getElementById('modalTitle').innerText = title;
        document.getElementById('modalDescription').innerText = description;
        document.getElementById('modalImage').src = imageUrl;

        // 3. Mostriamo la finestra (cambiando il CSS da display: none a display: flex)
        document.getElementById('projectModal').style.display = 'flex';

        // 4. Blocchiamo lo scorrimento della pagina di sfondo per non confondere l'utente
        document.body.style.overflow = 'hidden';
    }

    // Funzione per CHIUDERE la finestra
    function closeModal() {
        document.getElementById('projectModal').style.display = 'none';
        document.body.style.overflow = 'auto'; // Riattiviamo lo scorrimento
    }

    // Chicca extra: Chiudi il pop-up se l'utente clicca sullo sfondo nero scuro fuori dalla foto
    function closeModalOnOutsideClick(event) {
        const modal = document.getElementById('projectModal');
        if (event.target === modal) {
            closeModal();
        }
    }
</script>
</body>
</html>