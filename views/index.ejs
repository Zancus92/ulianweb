<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ULiAN | Fotografia & Social Media</title>
    <meta name="description" content="Portfolio di ULiAN, servizi esclusivi di Fotografia & Gestione Social Media." />

    <style>
        /* =========================================
           VARIABILI E IMPOSTAZIONI DI BASE
           ========================================= */
        :root {
            --bg: #0a0a0d;
            --bg-soft: #121218;
            --card: rgba(255,255,255,0.05);
            --card-border: rgba(255,255,255,0.08);
            --text: #f5f5f7;
            --muted: #b7b7c0;
            --accent: #ff5f87; /* Rosa acceso */
            --accent-2: #ff7aa1;
            --gold: #ffd700; /* Oro per elementi in evidenza */
            --white: #ffffff;
            --shadow: 0 20px 60px rgba(0,0,0,0.35);
            --radius: 24px;
            --max: 1200px;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Inter', ui-sans-serif, system-ui, -apple-system, sans-serif;
            background:
                    radial-gradient(circle at top right, rgba(255,95,135,0.12), transparent 25%),
                    radial-gradient(circle at bottom left, rgba(255,95,135,0.1), transparent 22%),
                    var(--bg);
            color: var(--text);
            line-height: 1.6;
            overflow-x: hidden;
        }

        a {
            color: inherit;
            text-decoration: none;
        }

        /* Effetto Rumore (Noise) di sfondo */
        .noise {
            position: fixed;
            inset: 0;
            pointer-events: none;
            opacity: 0.035;
            background-image: radial-gradient(circle, #fff 0.8px, transparent 0.8px);
            background-size: 12px 12px;
            z-index: 1;
        }

        /* Cursore luminoso che segue il mouse */
        .cursor-glow {
            position: fixed;
            width: 300px;
            height: 300px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(255,95,135,0.18), transparent 65%);
            pointer-events: none;
            transform: translate(-50%, -50%);
            z-index: 0;
            filter: blur(18px);
        }

        /* =========================================
           HEADER E NAVIGAZIONE
           ========================================= */
        header {
            position: sticky;
            top: 0;
            z-index: 30;
            backdrop-filter: blur(14px);
            background: rgba(10,10,13,0.55);
            border-bottom: 1px solid rgba(255,255,255,0.06);
        }

        .nav {
            max-width: var(--max);
            margin: 0 auto;
            padding: 16px 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 20px;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 14px;
            font-weight: 700;
            letter-spacing: 0.02em;
        }

        .brand-text span {
            display: block;
            font-size: 0.8rem;
            color: var(--muted);
            font-weight: 500;
        }

        .nav-links {
            display: flex;
            gap: 18px;
            flex-wrap: wrap;
        }

        .nav-links a {
            color: var(--muted);
            font-size: 0.95rem;
            transition: 0.25s ease;
        }

        .nav-links a:hover {
            color: var(--white);
        }

        /* =========================================
           SEZIONE HERO (Intestazione Principale)
           ========================================= */
        section {
            position: relative;
            z-index: 2;
        }

        .container {
            max-width: var(--max);
            margin: 0 auto;
            padding: 90px 20px;
        }

        .hero {
            min-height: 80vh;
            display: flex;
            align-items: center;
        }

        .hero-grid {
            display: grid;
            grid-template-columns: 1.2fr 0.8fr;
            gap: 40px;
            align-items: center;
        }

        .eyebrow {
            display: inline-flex;
            gap: 10px;
            align-items: center;
            padding: 10px 14px;
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 999px;
            background: rgba(255,255,255,0.03);
            color: var(--muted);
            margin-bottom: 22px;
            font-size: 0.92rem;
        }

        .eyebrow::before {
            content: "";
            width: 8px;
            height: 8px;
            background: var(--accent);
            border-radius: 50%;
            box-shadow: 0 0 18px var(--accent);
        }

        h1 {
            font-size: clamp(2.6rem, 7vw, 5rem);
            line-height: 1.05;
            letter-spacing: -0.03em;
            margin-bottom: 22px;
        }

        .gradient-text {
            background: linear-gradient(135deg, #fff, #ff95b5, #ff5f87);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .hero p {
            font-size: 1.08rem;
            color: var(--muted);
            max-width: 640px;
            margin-bottom: 30px;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            padding: 14px 22px;
            border-radius: 999px;
            border: 1px solid rgba(255,255,255,0.08);
            transition: transform 0.25s ease, background 0.25s ease, border-color 0.25s ease;
            font-weight: 700;
        }

        .btn:hover { transform: translateY(-3px); }

        .btn-primary {
            background: linear-gradient(135deg, var(--accent), var(--accent-2));
            border: none;
            box-shadow: 0 12px 30px rgba(255,95,135,0.25);
        }

        /* Card 3D nella Hero */
        .hero-card {
            position: relative;
            background: linear-gradient(180deg, rgba(255,255,255,0.08), rgba(255,255,255,0.03));
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 30px;
            padding: 28px;
            box-shadow: var(--shadow);
            overflow: hidden;
            transform-style: preserve-3d;
        }

        .hero-card::before {
            content: "";
            position: absolute;
            inset: -20%;
            background: radial-gradient(circle at top right, rgba(255,95,135,0.22), transparent 35%);
            pointer-events: none;
        }

        .mini-label {
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: 0.16em;
            font-size: 0.78rem;
            margin-bottom: 10px;
        }

        .hero-card h3 {
            font-size: 1.9rem;
            margin-bottom: 10px;
        }

        .hero-card p {
            color: var(--muted);
            margin-bottom: 20px;
        }

        /* =========================================
           SEZIONE PORTFOLIO (Dinamica)
           ========================================= */
        .section-head {
            display: flex;
            justify-content: space-between;
            align-items: end;
            gap: 20px;
            margin-bottom: 34px;
            flex-wrap: wrap;
        }

        .section-head h2 {
            font-size: clamp(2rem, 4vw, 3.4rem);
            line-height: 1;
            letter-spacing: -0.04em;
        }

        .section-head p {
            color: var(--muted);
            max-width: 580px;
        }

        .portfolio-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 24px;
        }

        /* Stile della singola card di un progetto caricato */
        .project {
            position: relative;
            min-height: 380px;
            border-radius: 28px;
            overflow: hidden;
            border: 1px solid rgba(255,255,255,0.08);
            padding: 24px;
            display: flex;
            flex-direction: column;
            justify-content: end;
            transition: transform 0.4s ease, box-shadow 0.4s ease;
            background-size: cover;
            background-position: center;
        }

        .project:hover {
            transform: translateY(-10px) scale(1.02);
            box-shadow: 0 20px 40px rgba(0,0,0,0.4);
            border-color: rgba(255,95,135,0.3);
        }

        /* Il gradiente scuro sopra l'immagine per rendere leggibile il testo */
        .project::after {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(180deg, rgba(10,10,13,0.1) 0%, rgba(10,10,13,0.95) 100%);
            z-index: 0;
            transition: opacity 0.3s ease;
        }

        .project > * {
            position: relative;
            z-index: 1;
        }

        /* Stile del Badge per i progetti in evidenza */
        .badge-featured {
            position: absolute;
            top: 20px;
            right: 20px;
            background: rgba(255, 215, 0, 0.15); /* Oro trasparente */
            color: var(--gold);
            padding: 6px 14px;
            border-radius: 999px;
            font-size: 0.82rem;
            font-weight: 700;
            border: 1px solid rgba(255, 215, 0, 0.3);
            backdrop-filter: blur(8px);
            z-index: 2;
        }

        .project h3 {
            font-size: 1.5rem;
            margin-bottom: 8px;
            color: var(--white);
        }

        .project p {
            color: #d8d8df;
            font-size: 0.95rem;
            line-height: 1.5;
            /* Tronca il testo se è troppo lungo (max 3 righe) */
            display: -webkit-box;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .empty-msg {
            grid-column: 1 / -1;
            text-align: center;
            padding: 4rem;
            color: var(--muted);
            border: 1px dashed rgba(255,255,255,0.1);
            border-radius: 24px;
        }

        /* =========================================
           FOOTER E ANIMAZIONI
           ========================================= */
        footer {
            border-top: 1px solid rgba(255,255,255,0.06);
            position: relative;
            z-index: 2;
            background: rgba(10,10,13,0.8);
            margin-top: 40px;
        }

        .footer-inner {
            max-width: var(--max);
            margin: 0 auto;
            padding: 28px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 20px;
            flex-wrap: wrap;
            color: var(--muted);
        }

        .admin-link {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 16px;
            background: rgba(255,255,255,0.05);
            border-radius: 999px;
            border: 1px solid rgba(255,255,255,0.1);
            transition: all 0.3s;
        }

        .admin-link:hover {
            background: rgba(255,255,255,0.1);
            color: var(--white);
        }

        /* Classi per l'animazione di comparsa allo scroll */
        .reveal {
            opacity: 0;
            transform: translateY(40px);
            transition: opacity 0.7s ease, transform 0.7s ease;
        }

        .reveal.visible {
            opacity: 1;
            transform: translateY(0);
        }

        @media (max-width: 800px) {
            .hero-grid { grid-template-columns: 1fr; }
            h1 { font-size: clamp(2.4rem, 12vw, 4.2rem); }
            .nav { flex-direction: column; }
        }
    </style>
</head>
<body>
<div class="noise"></div>
<div class="cursor-glow" id="cursorGlow"></div>

<header>
    <nav class="nav">
        <a href="/" class="brand">
            <div class="brand-text">
                <span style="color: var(--white); font-size: 1.2rem; font-weight: 800;">ULiAN</span>
                <span>Studio Visivo</span>
            </div>
        </a>
        <div class="nav-links">
            <a href="#home">Home</a>
            <a href="#portfolio">Portfolio</a>
        </div>
    </nav>
</header>

<main>
    <section class="hero" id="home">
        <div class="container">
            <div class="hero-grid">
                <div class="reveal">
                    <div class="eyebrow">Fotografia & Social Media</div>
                    <h1>
                        Contenuti <span class="gradient-text">visivi</span><br />
                        che lasciano il segno.
                    </h1>
                    <p>
                        Servizi esclusivi di fotografia, direzione creativa e gestione social media.
                        Realizzo identità visive per brand che vogliono farsi notare con uno stile moderno e d'impatto.
                    </p>
                    <a href="#portfolio" class="btn btn-primary">Esplora il Portfolio</a>
                </div>

                <div class="hero-card reveal" id="tiltCard">
                    <div class="mini-label">Servizi Esclusivi</div>
                    <h3>Creatività che comunica.</h3>
                    <p>
                        Dal set fotografico alla strategia social: curo l'immagine del tuo brand a 360 gradi.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <section id="portfolio">
        <div class="container">
            <div class="section-head reveal">
                <div>
                    <div class="eyebrow">Lavori Selezionati</div>
                    <h2>Il mio Portfolio.</h2>
                </div>
                <p>Esplora i progetti realizzati. L'eccellenza visiva applicata a casi studio reali, campagne social e shooting fotografici.</p>
            </div>

            <div class="portfolio-grid">
                <% if (typeof projects !== 'undefined' && projects.length === 0) { %>
                    <div class="empty-msg reveal">
                        Nessun progetto presente. Accedi all'area riservata per creare il tuo portfolio.
                    </div>
                <% } else if (typeof projects !== 'undefined') { %>

                    <% projects.forEach(function(project, index) { %>
                        <article class="project reveal" style="background-image: url('<%= project.image_url %>'); transition-delay: <%= (index % 3) * 0.1 %>s">

                            <% if (project.featured) { %>
                                <div class="badge-featured">⭐ In Evidenza</div>
                            <% } %>

                            <h3><%= project.title %></h3>
                            <p><%= project.description %></p>
                        </article>
                    <% }); %>

                <% } %>
            </div>
        </div>
    </section>
</main>

<footer>
    <div class="footer-inner">
        <div>© 2026 ULiAN Studio. Tutti i diritti riservati.</div>
        <a href="/login" class="admin-link">⚙️ Accesso Amministratore</a>
    </div>
</footer>

<script>
    // 1. Animazione di "Comparsa" (Fade Up) mentre scorri la pagina
    const reveals = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('visible');
            }
        });
    }, { threshold: 0.15 });

    reveals.forEach(el => observer.observe(el));

    // 2. Luce che segue il cursore
    const glow = document.getElementById('cursorGlow');
    window.addEventListener('mousemove', (e) => {
        glow.style.left = e.clientX + 'px';
        glow.style.top = e.clientY + 'px';
    });

    // 3. Effetto 3D (Tilt) sulla card nella Hero
    const tiltCard = document.getElementById('tiltCard');
    tiltCard.addEventListener('mousemove', (e) => {
        const rect = tiltCard.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;

        const rotateY = ((x / rect.width) - 0.5) * 12;
        const rotateX = ((y / rect.height) - 0.5) * -12;

        tiltCard.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg)`;
    });

    tiltCard.addEventListener('mouseleave', () => {
        tiltCard.style.transform = 'perspective(1000px) rotateX(0deg) rotateY(0deg)';
    });
</script>
</body>
</html>